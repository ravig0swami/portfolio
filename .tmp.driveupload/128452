<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64">
  <defs>
    <style>
      .logo-bg { fill: #000000; }
      .logo-r { fill: #ffffff; }
      
      @media (prefers-color-scheme: light) {
        .logo-bg { fill: #000000; }
        .logo-r { fill: #ffffff; }
      }
      
      @media (prefers-color-scheme: dark) {
        .logo-bg { fill: #ffffff; }
        .logo-r { fill: #000000; }
      }
    </style>
  </defs>
  
  <!-- Circular Background -->
  <circle class="logo-bg" cx="32" cy="32" r="32"/>
  
  <!-- Stylized R Logo -->
  <g class="logo-r">
    <!-- R vertical stem -->
    <rect x="20" y="14" width="8" height="36" rx="2"/>
    
    <!-- R top bowl -->
    <path d="M 28 14 Q 38 14 38 22 Q 38 30 28 30 L 20 30" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
    
    <!-- R leg -->
    <path d="M 28 30 L 38 50" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
</svg>
